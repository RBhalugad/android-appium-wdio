{
    "name": "android-appium-wdio",
    "version": "1.0.0",
    "private": true,
    "description": "WebdriverIO + Appium starter for testing an Android app on a real device (TypeScript)",
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    },
    "scripts": {
        "test:android": "wdio run ./config/wdio.android.conf.ts",
        "test:android:browserstack": "wdio run ./config/wdio.android.browserstack.conf.ts",
        "test:ios": "wdio run ./config/wdio.ios.conf.ts",
        "test:ios:browserstack": "wdio run ./config/wdio.ios.browserstack.conf.ts",
        "postinstall": "tsx scripts/patch-webdriver.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "report": "allure generate allure-results --clean && allure open"
    },
    "devDependencies": {
        "@types/node": "^24.13.3",
        "@wdio/allure-reporter": "^9.29.1",
        "@wdio/appium-service": "^9.29.1",
        "@wdio/browserstack-service": "^9.29.1",
        "@wdio/cli": "^9.29.1",
        "@wdio/globals": "^9.29.1",
        "@wdio/local-runner": "^9.29.1",
        "@wdio/mocha-framework": "^9.29.1",
        "@wdio/spec-reporter": "^9.29.1",
        "allure-commandline": "^2.43.0",
        "prettier": "^3.9.5",
        "tsx": "^4.23.0",
        "typescript": "^7.0.2"
    },
    "overrides": {
        "serialize-javascript": "^7.0.7"
    }
}
